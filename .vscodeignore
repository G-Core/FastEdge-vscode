# Exclude node_modules
node_modules/**

# Exclude test files
tests/**

# Exclude build scripts
scripts/**

# Exclude configuration files
.vscode/**
.gitignore
**/.gitkeep
.vscodeignore
tsconfig.json
package-lock.json
pnpm-lock.yaml
.node-version
eslint.config.mjs

# Exclude build config
.github
esbuild/**

# Exclude documentation
docs/**
context/**
DOTENV.md
claude.md

# Exclude exampleFolder
exampleFolder/**

# Exclude src files
**/*.ts
src/**

# Exclude map files
**/*.js.map

# IMPORTANT: Include the bundled debugger in the extension package
# The dist/debugger/ folder contains the fastedge-debugger server
# This must NOT be excluded - it's required for the extension to work
!dist/debugger/**

# But exclude node_modules inside debugger (causes vsce packaging issues)
dist/debugger/node_modules/**



